{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "src": "/stream/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/[...path].py": {
      "maxDuration": 30
    }
  },
  "env": {
    "USE_MOCK": "true",
    "AUTH_SECRET": "ryH*!GGTc33Y*D"
  }
}

