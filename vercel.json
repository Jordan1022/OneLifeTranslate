{
    "version": 2,
    "builds": [
        {
            "src": "vercel_api.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/vercel_api.py"
        }
    ]
}